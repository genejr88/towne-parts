generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

model Vendor {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  ros       RO[]

  @@map("vendors")
}

model RO {
  id                      Int           @id @default(autoincrement())
  roNumber                String        @unique
  vehicleYear             String?
  vehicleMake             String?
  vehicleModel            String?
  vehicleColor            String?
  vin                     String?
  vendorId                Int?
  vendor                  Vendor?       @relation(fields: [vendorId], references: [id])
  partsStatus             PartsStatus   @default(MISSING)
  productionStage         String?       @default("unassigned")
  productionStatusNote    String?
  productionWaitingParts  String?
  productionNextStep      String?
  productionFinalSupplement Boolean     @default(false)
  productionSupplementNote String?
  productionUpdatedAt     DateTime?
  isTotalLoss             Boolean       @default(false)
  assignedTech            String?
  isArchived              Boolean       @default(false)
  archivedAt              DateTime?
  locationPhotoUrl        String?

  // Customer / Owner info
  ownerName               String?
  ownerPhone              String?
  ownerPhone2             String?
  ownerEmail              String?

  // Insurance info
  insuranceCompany        String?
  claimNumber             String?
  policyNumber            String?
  adjusterName            String?
  adjusterPhone           String?
  deductible              Decimal?      @db.Decimal(10, 2)
  dateOfLoss              DateTime?

  parts                   Part[]
  invoices                ROInvoice[]
  locationPhotos          ROLocationPhoto[]
  srcEntries              SRCEntry[]
  activityLog             ActivityLog[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@map("ros")
}

model ROLocationPhoto {
  id               Int      @id @default(autoincrement())
  roId             Int
  ro               RO       @relation(fields: [roId], references: [id], onDelete: Cascade)
  storedPath       String
  caption          String?
  createdAt        DateTime @default(now())

  @@map("ro_location_photos")
}

enum PartsStatus {
  MISSING
  ACKNOWLEDGED
  ALL_HERE
}

model Part {
  id           Int          @id @default(autoincrement())
  roId         Int
  ro           RO           @relation(fields: [roId], references: [id], onDelete: Cascade)
  qty          Int          @default(1)
  partNumber   String?
  description  String?
  dateOrdered  DateTime?
  etaDate      DateTime?
  finishStatus FinishStatus @default(NO_FINISH_NEEDED)
  isReceived   Boolean      @default(false)
  hasCore      Boolean      @default(false)
  receivedAt   DateTime?
  price        Decimal?     @db.Decimal(10, 2)
  notes        String?
  photos       PartPhoto[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("parts")
}

enum FinishStatus {
  NEEDS_PAINT
  PAINTED
  TEXTURED
  NO_FINISH_NEEDED
}

model PartPhoto {
  id               Int      @id @default(autoincrement())
  partId           Int
  part             Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  originalFilename String?
  storedPath       String
  createdAt        DateTime @default(now())

  @@map("part_photos")
}

model ROInvoice {
  id               Int      @id @default(autoincrement())
  roId             Int
  ro               RO       @relation(fields: [roId], references: [id], onDelete: Cascade)
  originalFilename String?
  storedPath       String
  uploadedBy       String?
  fileType         String   @default("INVOICE")
  createdAt        DateTime @default(now())

  @@map("ro_invoices")
}

model SRCEntry {
  id              Int        @id @default(autoincrement())
  roId            Int?
  ro              RO?        @relation(fields: [roId], references: [id], onDelete: Cascade)
  entryType       SRCType
  status          SRCStatus  @default(OPEN)
  note            String?
  partNumber      String?
  partDescription String?
  vendorName      String?
  returnDate      DateTime?
  createdBy       String?
  completedAt     DateTime?
  photos          SRCPhoto[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("src_entries")
}

model SRCPhoto {
  id               Int      @id @default(autoincrement())
  srcEntryId       Int
  srcEntry         SRCEntry @relation(fields: [srcEntryId], references: [id], onDelete: Cascade)
  originalFilename String?
  storedPath       String
  createdAt        DateTime @default(now())

  @@map("src_photos")
}

enum SRCType {
  RETURN
  CORE_RETURN
}

enum SRCStatus {
  OPEN
  RETURNED
  CREDITED
  COMPLETED // retained for backward compat — no longer created by new code
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  roId      Int
  ro        RO       @relation(fields: [roId], references: [id], onDelete: Cascade)
  eventType String?
  message   String?
  createdAt DateTime @default(now())

  @@map("activity_log")
}

model PrivateFile {
  id               Int      @id @default(autoincrement())
  storedPath       String
  originalFilename String?
  caption          String?
  createdAt        DateTime @default(now())

  @@map("private_files")
}

model InventoryPart {
  id          String               @id @default(cuid())
  partNumber  String?
  description String
  qty         Int                  @default(1)
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  photos      InventoryPartPhoto[]
}

model InventoryPartPhoto {
  id                String        @id @default(cuid())
  inventoryPartId   String
  inventoryPart     InventoryPart @relation(fields: [inventoryPartId], references: [id], onDelete: Cascade)
  originalFilename  String
  storedPath        String
  createdAt         DateTime      @default(now())
}
